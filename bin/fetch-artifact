set -e

# OK if the source checkout is outdated -- we're just fetching a prebuild
ENV_SH_SKIP_WEBRTC_VERSION_CHECK=1

# shellcheck source=bin/env.sh
. "$(dirname "$0")"/env.sh

"${0}.py"                                \
    --output-dir="${OUTPUT_DIR}"         \
    --webrtc-version="${WEBRTC_VERSION}" \
    "$@"
